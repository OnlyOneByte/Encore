{
  "name": "@encore/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --bun vite dev",
    "build": "bun --bun vite build",
    "preview": "bun --bun vite preview",
    "start": "bun run ./build/index.js",
    "prepare": "bun --bun svelte-kit sync || echo ''",
    "check": "bun --bun svelte-kit sync && bun --bun svelte-check --tsconfig ./tsconfig.json",
    "typecheck": "bun --bun svelte-kit sync && bun --bun svelte-check --tsconfig ./tsconfig.json"
  },
  "dependencies": {
    "@encore/shared": "workspace:*",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@sveltejs/kit": "^2.63.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "bun-types": "^1.3.14",
    "drizzle-kit": "^0.31.10",
    "svelte": "^5.56.1",
    "svelte-adapter-bun": "^1.0.1",
    "svelte-check": "^4.6.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.16"
  }
}
