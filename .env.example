# Encore core
PORT=3000

# MediaStore backend: `local` (default, one box) or `object` (MinIO/S3 for remote workers)
MEDIA_STORE=local
MEDIA_DIR=./media
DATA_DIR=./data

# Object-store (only when MEDIA_STORE=object) — see docs/MASTER-DESIGN.md §2
# S3_ENDPOINT=http://minio:9000
# S3_BUCKET=encore-media
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# Worker (container 2 — stems profile only)
ENCORE_CORE_WS=ws://core:3000/ws?role=worker
ENCORE_WORKER_CONCURRENCY=1
